# Copy this file to terraform.tfvars and fill in the values
# Never commit terraform.tfvars to version control

ecr_repository_name        = "stocks-monitor-agent"
stocks_table_name          = "stocks-monitor-stocks-list"
sns_topic_name             = "stocks-monitor-alerts"
iam_role_name              = "stocks-monitor-agentcore-role"
agentcore_runtime_name     = "StocksMonitorRuntime"
eventbridge_schedule_name  = "stocks-monitor-daily-trigger"
claude_model_id            = "amazon.nova-micro-v1:0"
daily_drop_threshold_percent  = 2
weekly_drop_threshold_percent = 5

# Set after building and pushing the agent container image
container_image_uri = "<aws-account-id>.dkr.ecr.us-east-1.amazonaws.com/stocks-monitor-agent:latest"

# Lambda invoker
lambda_invoker_ecr_repository_name = "stocks-monitor-lambda-invoker"
lambda_invoker_role_name           = "stocks-monitor-lambda-invoker-role"
lambda_invoker_function_name       = "stocks-monitor-lambda-invoker"

# Set after building and pushing the Lambda invoker container image
lambda_invoker_image_uri = "<aws-account-id>.dkr.ecr.us-east-1.amazonaws.com/stocks-monitor-lambda-invoker:latest"

recipient_email_addresses = [
  "<recipient-email-1>",
  "<recipient-email-2>"
]

# SES notification (optional) — leave empty or remove to use SNS only.
# If provided, SES will be used instead of SNS.
# The SES identity must already be verified (managed by another repo).
# ses_sender_email_address = "<sender-email>"

# CloudWatch log retention (days)
log_retention_days = 7

# Existing log groups to manage retention on (e.g. Lambda function log groups)
existing_log_group_names = [
  "/aws/lambda/<your-lambda-function-name>"
]
